meta {
  name: Update currency
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/currencies/{{currencyCode}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "code": "{{currencyCode}}",
    "name": "Euro",
    "symbol": "€",
    "decimalPlaces": 2,
    "symbolPosition": "before"
  }
}
