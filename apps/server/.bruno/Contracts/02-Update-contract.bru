meta {
  name: Update contract
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/contracts/{{contractId}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "pocketId": "{{pocketId}}",
    "partnerId": "{{partnerId}}",
    "name": "Mobile plan",
    "startDate": "2026-01-01",
    "endDate": null,
    "notes": "Updated sample contract"
  }
}
